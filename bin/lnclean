#!/bin/bash
set -eu

# Check whether a path is a broken symlink (points at a missing target)
is_broken_symlink() {
  [ -L "$1" ] && [ ! -e "$1" ]
}

# Directory to scan (default: current)
DIR=${1:-.}

# Remove every broken symlink under DIR
while read -r symlink; do
  if is_broken_symlink "$symlink"; then
    echo "Broken symlink found: $symlink"
    rm "$symlink"
  fi
done < <(find "$DIR" -type l)
