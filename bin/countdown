#!/usr/bin/env zsh
# Countdown timer. Usage: countdown <positive-seconds>

if [[ $# -ne 1 || "$1" != <1-> ]]; then
    echo "Usage: $0 <positive-seconds>" >&2
    exit 1
fi

# "Time's up" alert, portable across macOS/Linux with a terminal-bell fallback.
alert() {
    if command -v afplay >/dev/null 2>&1; then
        afplay /System/Library/Sounds/Glass.aiff 2>/dev/null
    elif command -v paplay >/dev/null 2>&1; then
        paplay /usr/share/sounds/freedesktop/stereo/complete.oga 2>/dev/null
    else
        printf '\a'
    fi
}

seconds=$1
start=$SECONDS
while (( SECONDS - start < seconds )); do
    remaining=$(( seconds - (SECONDS - start) ))
    printf '\r%02d:%02d:%02d' \
        $(( remaining / 3600 )) $(( (remaining % 3600) / 60 )) $(( remaining % 60 ))
    sleep 1
done
printf "\rTime's up!\n"
alert
