#!/usr/bin/env bash
# Git post-checkout hook - Auto-sync dotfiles after branch switches

set -uo pipefail

# Only run if we're actually switching branches (not just checking out files)
# $1 = previous HEAD, $2 = new HEAD, $3 = flag (1 if branch checkout, 0 if file checkout)
if [[ "${3:-}" == "1" ]]; then
  # Get the repository root
  REPO_ROOT="$(git rev-parse --show-toplevel)"

  # Sync when configuration or lifecycle logic changes.  `bin/dotfiles sync`
  # resolves the stored profile instead of falling back to minimal.
  if git diff --name-only "${1:-}" "${2:-}" | grep -Eq '^(config/|install/|bin/|bootstrap\.sh$)'; then
    echo "✨ Dotfiles configuration changed, syncing..."

    # Run sync in the background (logged) so git operations stay fast
    mkdir -p "$HOME/.cache"
    (
      cd "$REPO_ROOT" || exit
      ./bin/dotfiles sync
    ) >>"$HOME/.cache/dotfiles-sync.log" 2>&1 &

    # Give user a hint about the background sync
    echo "   Syncing dotfiles in background (log: ~/.cache/dotfiles-sync.log)"
  fi
fi
