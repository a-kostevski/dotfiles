#!/usr/bin/env bash
# Git post-merge hook - Auto-sync dotfiles after pulls/merges

set -uo pipefail

# Get the repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"

# Check configuration and lifecycle inputs.  The CLI resolves the stored
# profile, so a hook never silently reconciles only the minimal profile.
if git diff --name-only 'HEAD@{1}' HEAD | grep -Eq '^(config/|install/|bin/|bootstrap\.sh$)'; then
    echo "✨ Dotfiles configuration updated, syncing..."

    # Run sync
    cd "$REPO_ROOT" || exit
    ./bin/dotfiles sync

    echo "   Sync complete! Restart your terminal or run: source ~/.zshenv"
fi
